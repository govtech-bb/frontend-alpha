# AWS SES Configuration
SES_REGION=us-east-1
SES_FROM_EMAIL=no-reply@notify.dev.alpha.gov.bb
FEEDBACK_FROM_EMAIL=no-reply@notify.dev.alpha.gov.bb
FEEDBACK_TO_EMAIL=no-reply@notify.dev.alpha.gov.bb
MAIL_FROM=no-reply@notify.dev.alpha.gov.bb

# When AWS_PROFILE=dev, remote form notification emails go here (must be verified in SES sandbox).
# SES_DEV_NOTIFICATION_EMAIL=testing@govtech.bb

SES_CONFIGURATION_SET="PASTE_VALUE_HERE"
SES_TAG_KEY="PASTE_VALUE_HERE"

# Analytics
NEXT_PUBLIC_UMAMI_SITE_ID="PASTE_VALUE_HERE"

# Remote API
NEXT_PUBLIC_PROCESSING_API="PASTE_VALUE_HERE"

# Optional: map S3 formSlug to processing API submit key (JSON object)
# NEXT_PUBLIC_FORM_SUBMIT_KEY_MAP='{"project-dawn-training-programme-application":"apply-for-project-dawn"}'

# S3 form definitions for /forms/[formSlug]/form (server-only; omit to 404 remote form pages)
# FORMS_S3_BUCKET=
# FORMS_S3_PREFIX=
# FORMS_S3_REGION=us-east-1

# Necessary for local AWS CLI access on the dev profile
AWS_PROFILE=dev

# Enable if you want to disable protected pages
# RESEARCH_ACCESS_TOKEN="demo"

# Set the environment to development (to disable Umami analytics)
NODE_ENV=development
