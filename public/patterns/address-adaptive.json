{
  "id": "address-adaptive",
  "version": "1.0.0",
  "name": "Address (Adaptive)",
  "description": "Adapts address fields based on user's country - supports Barbados, USA, UK, and international formats",
  "category": "input",
  "adaptive": true,
  "variants": [
    {
      "country": "BB",
      "name": "Barbados Address",
      "fields": [
        {
          "name": "addressLine1",
          "type": "text",
          "label": "Address Line 1",
          "validation": {
            "required": true,
            "minLength": 5,
            "maxLength": 100,
            "message": "Address must be at least 5 characters"
          }
        },
        {
          "name": "addressLine2",
          "type": "text",
          "label": "Address Line 2",
          "validation": {
            "required": false,
            "maxLength": 100
          }
        },
        {
          "name": "parish",
          "type": "select",
          "label": "Parish",
          "validation": {
            "required": true
          },
          "options": [
            { "value": "", "label": "" },
            { "value": "christ-church", "label": "Christ Church" },
            { "value": "st-andrew", "label": "St. Andrew" },
            { "value": "st-george", "label": "St. George" },
            { "value": "st-james", "label": "St. James" },
            { "value": "st-john", "label": "St. John" },
            { "value": "st-joseph", "label": "St. Joseph" },
            { "value": "st-lucy", "label": "St. Lucy" },
            { "value": "st-michael", "label": "St. Michael" },
            { "value": "st-peter", "label": "St. Peter" },
            { "value": "st-philip", "label": "St. Philip" },
            { "value": "st-thomas", "label": "St. Thomas" }
          ]
        },
        {
          "name": "postalCode",
          "type": "text",
          "label": "Postcode",
          "helpText": "For example, BB17004",
          "placeholder": "BB17004",
          "validation": {
            "required": false,
            "pattern": "^BB\\d{5}$",
            "message": "Enter a valid postcode (for example, BB17004)"
          }
        }
      ]
    },
