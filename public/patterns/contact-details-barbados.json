{
  "$schema": "../../schemas/pattern-schema.json",
  "id": "contact-details-barbados",
  "version": "1.0.0",
  "name": "Contact Details (Barbados)",
  "description": "Email and phone contact information with Barbados-specific phone number validation",
  "category": "input",
  "metadata": {
    "tags": ["contact", "email", "phone", "barbados"],
    "examples": ["get-birth-certificate", "conductor-licence", "all-forms"],
    "author": "Forms Team",
    "region": "Barbados"
  },
  "fields": [
    {
      "name": "email",
      "type": "email",
      "label": "Email address",
      "validation": {
        "required": "Email address is required"
      }
    },
    {
      "name": "telephoneNumber",
      "type": "tel",
      "label": "Telephone number",
      "validation": {
        "required": "Telephone number is required",
        "pattern": "^(1[-]246[-]\\d{3}[-]\\d{4}|1[\\s]246[\\s]\\d{3}[\\s]\\d{4}|1246\\d{7})$"
      },
      "helpText": "Please enter a valid phone number (for example, 12462345678, 1-246-234-5678, or 1 246 234 5678)"
    }
  ]
}
